{
  "version": "0.1.3",
  "name": "visionary-base64url",
  "description": "A lightweight library for URL-safe Base64 encoding and decoding.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist/",
    "prepublishOnly": "npm run clean && npm run build && npm run test:ci",
    "test": "vitest",
    "test:ci": "vitest run"
  },
  "license": "ISC",
  "keywords": [
    "base64url",
    "base64",
    "decoder",
    "encoder",
    "url",
    "url-safe",
    "utility",
    "visionary"
  ],
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/visionary-ux/visionary-base64url.git"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "rimraf": "5.0.10",
    "typescript": "5.9.3",
    "vitest": "4.0.4"
  },
  "dependencies": {
    "js-base64": "3.7.8"
  }
}
